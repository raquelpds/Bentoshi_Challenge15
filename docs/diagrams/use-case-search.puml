@startuml
left to right direction

actor "Usuário" as User

rectangle "Bentochi" {
  usecase "Buscar conteúdos" as UC1
  usecase "Buscar em todos\nos bentochis" as UC2
  usecase "Buscar dentro de\num bentochi" as UC3
  usecase "Indexar palavras-chave" as UC4
  usecase "Normalizar termos\nde busca" as UC5
  usecase "Exibir resultados\npor tipo" as UC6
  usecase "Abrir origem\ndo resultado" as UC7
}

User --> UC1
User --> UC7

UC1 <|-- UC2
UC1 <|-- UC3

UC1 ..> UC5 : <<include>>
UC1 ..> UC6 : <<include>>
UC4 ..> UC5 : <<include>>

@enduml