@startuml
left to right direction

actor "Usuário" as User

rectangle "Bentochi" {
  usecase "Criar bentochi" as UC1
  usecase "Editar nome\ndo bentochi" as UC2
  usecase "Alterar cor\nde capa" as UC3
  usecase "Excluir bentochi" as UC4
  usecase "Listar bentochis" as UC5
  usecase "Ordenar bentochis" as UC6
  usecase "Validar nome\nobrigatório" as UC7
  usecase "Remover artefatos\nvinculados" as UC8
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6

UC1 ..> UC7 : <<include>>
UC2 ..> UC7 : <<include>>
UC4 ..> UC8 : <<include>>

@enduml