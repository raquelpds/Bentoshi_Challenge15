@startuml
left to right direction

actor "Usuário" as User
actor "Sistema de Arquivos\nmacOS" as FileSystem

rectangle "Bentochi" {
  usecase "Adicionar artefato" as UC1
  usecase "Adicionar arquivo" as UC2
  usecase "Adicionar link" as UC3
  usecase "Adicionar texto" as UC4
  usecase "Editar artefato" as UC5
  usecase "Excluir artefato" as UC6
  usecase "Validar nome\nobrigatório" as UC7
  usecase "Validar URL" as UC8
  usecase "Referenciar arquivo\nsem modificar original" as UC9
}

User --> UC1
User --> UC5
User --> UC6

UC1 <|-- UC2
UC1 <|-- UC3
UC1 <|-- UC4

UC1 ..> UC7 : <<include>>
UC3 ..> UC8 : <<include>>
UC2 ..> UC9 : <<include>>

UC9 --> FileSystem

@enduml